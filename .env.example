# Copy this file to .env for local Docker Compose runs:
#   cp .env.example .env
#
# Keep the names aligned with fly.toml / cmd/dndnd/main.go so local and cloud
# runs differ only by values, not by configuration shape.

# Local service ports.
APP_PORT=8080
POSTGRES_PORT=5432

# Local Postgres credentials used by docker-compose.yml.
POSTGRES_DB=dndnd
POSTGRES_USER=dndnd
POSTGRES_PASSWORD=dndnd

# Public base URL for OAuth redirects and portal links.
# Local Discord OAuth redirect:
#   http://localhost:8080/portal/auth/callback
# Fly Discord OAuth redirect:
#   https://<your-fly-app>.fly.dev/portal/auth/callback
BASE_URL=http://localhost:8080
COOKIE_SECURE=false

# Development logging and startup behavior.
DEBUG=true
SKIP_SRD_SEED=false

# Discord bot / OAuth credentials. Leave blank to run dashboard-only mode
# without a live bot; set all four for a real Discord playtest.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Used only when DISCORD_CLIENT_ID or DISCORD_CLIENT_SECRET is blank. Set this
# to your Discord user ID if you want local passthrough mode to match seeded
# campaign ownership.
DEV_DISCORD_USER_ID=local-dev

# Optional explicit OAuth callback. Leave blank unless a proxy/tunnel needs a
# different URL than BASE_URL + /portal/auth/callback.
OAUTH_REDIRECT_URL=

# Optional AES-GCM token encryption key for stored OAuth tokens.
# Must be 16, 24, or 32 bytes if set. Use a strong random 32-byte value in
# cloud deploys, for example from: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
